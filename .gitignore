# =============================================================================
# FREEPEN .gitignore
# Next.js 14 + TypeScript + Prisma + PostgreSQL
# =============================================================================

# ------------------------------------------------------------------------------
# SECURITY — never commit these
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging

# ------------------------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------------------------
node_modules/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ------------------------------------------------------------------------------
# Next.js build output
# ------------------------------------------------------------------------------
.next/
out/
build/

# ------------------------------------------------------------------------------
# Prisma generated client
# ------------------------------------------------------------------------------
node_modules/.prisma/
prisma/generated/

# Prisma migration lock is safe to commit, but the generated client is not
# (it is machine/platform-specific — regenerate with `npx prisma generate`)

# ------------------------------------------------------------------------------
# TypeScript
# ------------------------------------------------------------------------------
tsconfig.tsbuildinfo
*.tsbuildinfo

# ------------------------------------------------------------------------------
# Testing
# ------------------------------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------------------------
# OS / Editor
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ------------------------------------------------------------------------------
# Misc
# ------------------------------------------------------------------------------
*.pem
.vercel
.turbo